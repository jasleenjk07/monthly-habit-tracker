# Server
PORT=3001
JWT_SECRET=change-this-to-a-long-random-string

# Frontend URL (OAuth redirect after sign-in; set to your Vercel URL in production)
FRONTEND_URL=http://localhost:5173

# Extra allowed CORS origins (comma-separated), e.g. preview deploys
# CORS_ORIGINS=https://monthly-habit-tracker.vercel.app

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Frontend only (Vercel) — Railway backend URL, no trailing slash
# VITE_API_URL=https://your-app.up.railway.app
